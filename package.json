{
    "name": "pulseshop",
    "private": true,
    "workspaces": [
        "services/*",
        "packages/*"
    ],
    "scripts": {
        "build": "npm run build -ws --if-present",
        "dev:auth": "npm run dev -w @pulseshop/auth",
        "dev:product": "npm run dev -w @pulseshop/product"
    },
    "type": "module",
    "dependencies": {
        "bcrypt": "^6.0.0",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-validator": "^7.3.2",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.6.3",
        "morgan": "^1.10.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "tsc": "^2.0.4",
        "typescript": "^6.0.3"
    }
}
