{
  "name": "@pulseshop/shared",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/dist/src/index.js",
  "types": "./src/dist/src/index.d.ts",
  "exports": {
    "./error-handler": {
      "types": "./src/dist/src/error-handler.d.ts",
      "import": "./src/dist/src/error-handler.js",
      "default": "./src/dist/src/error-handler.js"
    },
    "./types": {
      "types": "./src/dist/src/types.d.ts",
      "import": "./src/dist/src/types.js",
      "default": "./src/dist/src/types.js"
    },
    "./index":{
      "import":"./src/dist/src/index.js",
      "default":"./src/dist/src/index.js"
    },
    "./asyncHandler":{
      "import":"./src/dist/src/asyncHandler.js",
      "default":"./src/dist/src/asyncHandler.js"
    },
    "./error-middleware":{
      "import":"./src/dist/src/middleware/error.middleware.js",
      "default":"./src/dist/src/middleware/error.middleware.js"
    },
    "./validate-middleware":{
      "import":"./src/dist/src/middleware/validate.middleware.js",
      "default":"./src/dist/src/middleware/validate.middleware.js"
    }
